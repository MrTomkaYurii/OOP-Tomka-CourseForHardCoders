---
import { getLabs } from "@/data/course";
import { pathWithoutBase, sitePath } from "@/utils/paths";
import ThemeToggle from "@/components/ThemeToggle.astro";
import TopBar from "@/components/TopBar.astro";
import BackToTop from "@/components/BackToTop.astro";

const labs = getLabs();
const currentPath = pathWithoutBase(Astro.url.pathname);
---

<input class="drawer-toggle left-toggle" type="checkbox" id="course-menu-toggle" aria-hidden="true" />
<div class="app-shell">
  <div class="mobile-bar">
    <label class="icon-button" for="course-menu-toggle" aria-label="Відкрити меню курсу">
      <span></span>
      <span></span>
      <span></span>
    </label>
    <a class="mobile-brand" href={sitePath("/")}>OOP Course</a>
    <ThemeToggle />
  </div>

  <label class="drawer-backdrop" for="course-menu-toggle" aria-label="Закрити меню"></label>

  <aside class="sidebar">
    <div class="drawer-head">
      <span>Меню курсу</span>
      <label class="close-button" for="course-menu-toggle" aria-label="Закрити меню">×</label>
    </div>

    <a class="brand" href={sitePath("/")}>
      <span class="brand-mark">C#</span>
      <span>
        <strong>OOP Course</strong>
        <small>Clinic system labs</small>
      </span>
    </a>

    <nav class="nav-block" aria-label="Основна навігація">
      <a class:list={["nav-link", currentPath === "/" && "active"]} href={sitePath("/")}>Огляд курсу</a>
      <a class:list={["nav-link", currentPath === "/labs/" && "active"]} href={sitePath("/labs/")}>Лабораторні</a>
      <a class:list={["nav-link", currentPath === "/roadmap/" && "active"]} href={sitePath("/roadmap/")}>Карта розвитку</a>
      <a class:list={["nav-link", currentPath === "/evolution/" && "active"]} href={sitePath("/evolution/")}>Еволюція проєкту</a>
    </nav>

    <div class="nav-section">
      <p>Лаби</p>
      <div class="lab-nav">
        {labs.map((lab) => (
          <a class:list={["lab-nav-link", currentPath === `/labs/${lab.slug}/` && "active"]} href={sitePath(`/labs/${lab.slug}/`)}>
            <span>{String(lab.number).padStart(2, "0")}</span>
            <strong>{lab.title}</strong>
          </a>
        ))}
      </div>
    </div>
  </aside>

  <main class="content-frame">
    <TopBar />
    <slot />
    <footer class="site-footer">
      <span>Розроблено</span>
      <strong>Tomka Yurii</strong>
    </footer>
  </main>
  <BackToTop />
</div>
