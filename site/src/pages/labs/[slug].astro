---
import AppShell from "@/components/AppShell.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getLab, getLabs } from "@/data/course";
import { sitePath } from "@/utils/paths";

export function getStaticPaths() {
  return getLabs().map((lab) => ({ params: { slug: lab.slug } }));
}

const lab = getLab(Astro.params.slug!);

if (!lab) {
  return Astro.redirect(sitePath("/labs/"));
}

const labs = getLabs();
const currentIndex = labs.findIndex((item) => item.slug === lab.slug);
const previousLab = currentIndex > 0 ? labs[currentIndex - 1] : undefined;
const nextLab = currentIndex >= 0 && currentIndex < labs.length - 1 ? labs[currentIndex + 1] : undefined;

const tocGroups = lab.headings.reduce<Array<{ parent: (typeof lab.headings)[number]; children: typeof lab.headings }>>(
  (groups, heading) => {
    if (heading.depth === 2) {
      groups.push({ parent: heading, children: [] });
      return groups;
    }

    if (heading.depth === 3 && groups.length > 0) {
      groups[groups.length - 1].children.push(heading);
    }

    return groups;
  },
  [],
);
---

<SiteLayout title={`${lab.title} | OOP C# Course`}>
  <AppShell>
    <article class="lab-layout">
      <header class="lab-hero">
        <div>
          <p class="eyebrow">Lab {String(lab.number).padStart(2, "0")}</p>
          <h1>{lab.title}</h1>
          <p>{lab.topic}</p>
        </div>
        <aside class="lab-facts">
          <div>
            <span>Модуль</span>
            <strong>{lab.module}</strong>
          </div>
          <div>
            <span>Гілка</span>
            <strong>{lab.branch}</strong>
          </div>
          <div>
            <span>Merge</span>
            <strong>{lab.merge}</strong>
          </div>
          <div>
            <span>Меню</span>
            <strong>{lab.menu}</strong>
          </div>
        </aside>
      </header>

      <input class="drawer-toggle right-toggle" type="checkbox" id="lab-toc-toggle" aria-hidden="true" />
      <label class="toc-fab" for="lab-toc-toggle" aria-label="Відкрити зміст лабораторної">
        <span></span>
        <span></span>
        <span></span>
      </label>
      <label class="toc-backdrop" for="lab-toc-toggle" aria-label="Закрити зміст"></label>

      <div class="reader-grid">
        <div class="markdown-body" set:html={lab.html} />
        <aside class="toc">
          <div class="drawer-head toc-drawer-head">
            <span>Зміст лабораторної</span>
            <label class="close-button" for="lab-toc-toggle" aria-label="Закрити зміст">×</label>
          </div>
          <p>На сторінці</p>
          {tocGroups.map((group, index) => (
            group.children.length > 0 ? (
              <details class="toc-group" open={index < 2 || group.parent.text.startsWith("Задача 1")}>
                <summary>
                  <a data-toc-link href={`#${group.parent.slug}`}>{group.parent.text}</a>
                </summary>
                <div>
                  {group.children.map((heading) => (
                    <a data-toc-link href={`#${heading.slug}`}>{heading.text}</a>
                  ))}
                </div>
              </details>
            ) : (
              <a data-toc-link class="toc-link" href={`#${group.parent.slug}`}>{group.parent.text}</a>
            )
          ))}
        </aside>
      </div>

      <nav class="lab-pager" aria-label="Навігація між лабораторними">
        {previousLab ? (
          <a class="pager-card previous" href={sitePath(`/labs/${previousLab.slug}/`)}>
            <span>Попередня</span>
            <strong>Lab {String(previousLab.number).padStart(2, "0")}: {previousLab.title}</strong>
          </a>
        ) : <span></span>}

        {nextLab ? (
          <a class="pager-card next" href={sitePath(`/labs/${nextLab.slug}/`)}>
            <span>Наступна</span>
            <strong>Lab {String(nextLab.number).padStart(2, "0")}: {nextLab.title}</strong>
          </a>
        ) : <span></span>}
      </nav>
    </article>

    <script>
      const headingNodes = [...document.querySelectorAll<HTMLElement>(".markdown-body h2[id], .markdown-body h3[id]")];
      const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]")];
      const linkById = new Map(tocLinks.map((link) => [decodeURIComponent(link.hash.slice(1)), link]));

      function activateTocLink(id: string) {
        tocLinks.forEach((link) => link.classList.toggle("active", decodeURIComponent(link.hash.slice(1)) === id));
        const activeLink = linkById.get(id);
        activeLink?.closest("details")?.setAttribute("open", "");
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

          if (visible?.target.id) {
            activateTocLink(visible.target.id);
          }
        },
        { rootMargin: "-18% 0px -70% 0px", threshold: 0.01 },
      );

      headingNodes.forEach((heading) => observer.observe(heading));
      if (headingNodes[0]?.id) {
        activateTocLink(headingNodes[0].id);
      }
    </script>
  </AppShell>
</SiteLayout>
