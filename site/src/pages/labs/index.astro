---
import AppShell from "@/components/AppShell.astro";
import LabCard from "@/components/LabCard.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getLabs } from "@/data/course";

const labs = getLabs();
---

<SiteLayout title="Лабораторні | OOP C# Course">
  <AppShell>
    <section class="page-title">
      <p class="eyebrow">Матеріали</p>
      <h1>Лабораторні роботи</h1>
      <p>Практичні завдання ведуть від базового синтаксису до розробки частин курсового проєкту.</p>
    </section>

    <section class="lab-grid">
      {labs.map((lab) => <LabCard lab={lab} />)}
    </section>
  </AppShell>
</SiteLayout>
